{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Model Router",
  "version": "0.4.0-beta.1",
  "identifier": "com.codexrouter.desktop",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "panel",
        "title": "Codex Model Router",
        "url": "index.html?view=panel",
        "width": 382,
        "height": 610,
        "minWidth": 360,
        "minHeight": 520,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": true
      },
      {
        "label": "island",
        "title": "Router activity",
        "url": "index.html?view=island",
        "width": 326,
        "height": 44,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "focus": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "Tray companion for Codex Model Router",
    "longDescription": "Monitor router activity, token usage, quotas, and provider connections from the Windows or Linux system tray.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
