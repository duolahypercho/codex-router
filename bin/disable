#!/bin/sh
set -eu

repo_dir=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
cd "$repo_dir"
target=${MODEL_ROUTER_TARGET:-codex}
case "$target" in
  codex) config_manager=src/config-manager.mjs ;;
  claude) config_manager=src/claude-config-manager.mjs ;;
  *) echo "MODEL_ROUTER_TARGET must be codex or claude." >&2; exit 2 ;;
esac
node "$config_manager" disable
node src/service.mjs uninstall
echo "External model routes disabled. Your model, provider, and profile settings were preserved."
echo "Fully quit and reopen $target."
