#!/bin/sh
set -eu

repo_dir=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
prepare_only=false
migrate_known=false
target=${MODEL_ROUTER_TARGET:-codex}

case "$target" in
  codex|claude|cursor) ;;
  *) echo "MODEL_ROUTER_TARGET must be codex, claude, or cursor." >&2; exit 2 ;;
esac

for argument in "$@"; do
  case "$argument" in
    --prepare-only) prepare_only=true ;;
    --migrate-known) migrate_known=true ;;
    *) echo "Usage: $0 [--prepare-only] [--migrate-known]" >&2; exit 2 ;;
  esac
done

if [ "$prepare_only" = true ] && [ "$migrate_known" = true ]; then
  echo "--prepare-only cannot migrate an active older router." >&2
  exit 2
fi
if [ "$target" != codex ] && [ "$migrate_known" = true ]; then
  echo "--migrate-known applies only to the Codex target." >&2
  exit 2
fi

platform=$(uname -s)
case "$platform" in
  Darwin|Linux) ;;
  *)
    if [ "$prepare_only" != true ]; then
      echo "Use install.ps1 for the native Windows installer." >&2
      exit 1
    fi
    ;;
esac
if [ "$target" = claude ] && [ "$platform" = Linux ] && [ "$prepare_only" != true ]; then
  echo "Claude Desktop third-party mode is supported on macOS and Windows; use --prepare-only for Linux development." >&2
  exit 1
fi

for tool in node npm; do
  if ! command -v "$tool" >/dev/null 2>&1; then
    echo "$tool is required but was not found on PATH." >&2
    exit 1
  fi
done

node -e 'const [a,b]=process.versions.node.split(".").map(Number); if (!(a>22 || (a===22 && b>=19))) { console.error("Node.js 22.19 or newer is required."); process.exit(1) }'

cd "$repo_dir"
if [ "$target" = codex ]; then
  codex_home=${CODEX_HOME:-$HOME/.codex}
  mkdir -p "$codex_home"
  if [ "$migrate_known" = true ]; then
    node src/legacy-migration.mjs apply --yes >/dev/null
  else
    node src/legacy-migration.mjs assert-clear >/dev/null
  fi
fi
if [ "$prepare_only" != true ]; then
  node src/provider-selection.mjs ensure-configured >/dev/null
fi
npm ci --omit=dev

if command -v uv >/dev/null 2>&1; then
  if [ ! -x .venv/bin/python ]; then
    uv venv --python 3.12 .venv
  fi
  uv pip install --python .venv/bin/python 'litellm[proxy]==1.93.0'
else
  if ! command -v python3 >/dev/null 2>&1; then
    echo "Python 3.10+ or uv is required to install LiteLLM." >&2
    exit 1
  fi
  python3 -c 'import sys; raise SystemExit(0 if sys.version_info >= (3, 10) else "Python 3.10 or newer is required.")'
  python3 -m venv .venv
  .venv/bin/python -m pip install --upgrade pip
  .venv/bin/python -m pip install 'litellm[proxy]==1.93.0'
fi

node src/secret.mjs ensure
if [ "$target" = codex ]; then
  state_dir=${MODEL_ROUTER_STATE_DIR:-${CODEX_ROUTER_STATE_DIR:-${KIMI_CODEX_STATE_DIR:-${CODEX_HOME:-$HOME/.codex}/codex-router}}}
  if [ -s "$state_dir/native-models.json" ]; then
    node src/catalog.mjs
  else
    node src/catalog.mjs --refresh-native
  fi
fi
node src/litellm-config.mjs

if [ "$prepare_only" = true ]; then
  echo "Dependencies and local $target router files are prepared. Application configuration was not changed."
  exit 0
fi

config_enabled=false
service_installed=false
if [ "$target" = claude ]; then
  config_manager=src/claude-config-manager.mjs
elif [ "$target" = cursor ]; then
  config_manager=src/cursor-config-manager.mjs
else
  config_manager=src/config-manager.mjs
fi
rollback() {
  if [ "$service_installed" = true ]; then
    node src/service.mjs uninstall >/dev/null 2>&1 || true
  fi
  if [ "$config_enabled" = true ]; then
    node "$config_manager" disable >/dev/null 2>&1 || true
  fi
}
trap rollback EXIT HUP INT TERM

config_enabled=true
node "$config_manager" enable
service_installed=true
node src/service.mjs install
node src/wait-health.mjs
node src/install-manifest.mjs record >/dev/null
config_enabled=false
service_installed=false
trap - EXIT HUP INT TERM

if [ "$target" = claude ]; then
  echo "Installed the selected external model routes for Claude Desktop."
  echo "Fully quit and reopen Claude Desktop. It will start in third-party inference mode."
  echo "Kimi API key: $repo_dir/bin/model-router claude provider-key kimi-api set"
  echo "DeepSeek API key: $repo_dir/bin/model-router claude provider-key deepseek set"
  echo "xAI API key: $repo_dir/bin/model-router claude provider-key grok-api set"
  echo "Anthropic API key: $repo_dir/bin/model-router claude provider-key anthropic-api set"
elif [ "$target" = cursor ]; then
  echo "Installed the local OpenAI-compatible gateway for Cursor."
  echo "Run '$repo_dir/bin/model-router cursor setup' for the Base URL, key, and model"
  echo "ids to paste into Cursor -> Settings -> Models. Cursor's own settings are untouched."
  echo "Kimi API key: $repo_dir/bin/model-router cursor provider-key kimi-api set"
  echo "DeepSeek API key: $repo_dir/bin/model-router cursor provider-key deepseek set"
  echo "xAI API key: $repo_dir/bin/model-router cursor provider-key grok-api set"
  echo "Anthropic API key: $repo_dir/bin/model-router cursor provider-key anthropic-api set"
else
  echo "Installed the selected external model routes for Codex."
  echo "Fully quit and reopen Codex, then start a new task."
  echo "Kimi API key: $repo_dir/bin/provider-key kimi-api set"
  echo "DeepSeek API key: $repo_dir/bin/provider-key deepseek set"
  echo "xAI API key: $repo_dir/bin/provider-key grok-api set"
  echo "Anthropic API key: $repo_dir/bin/provider-key anthropic-api set"
fi
